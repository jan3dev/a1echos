{
  "expo": {
    "name": "Echos",
    "slug": "echos",
    "version": "0.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-dark.png",
    "scheme": "echos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "deploymentTarget": "16.0",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Echos needs access to your microphone to record audio for transcription.",
        "UIBackgroundModes": ["audio"],
        "UILaunchStoryboardName": "SplashScreen"
      },
      "bundleIdentifier": "com.a1lab.echos"
    },
    "android": {
      "versionCode": 9,
      "minSdkVersion": 26,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK"
      ],
      "package": "com.a1lab.echos"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/icon-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "./plugins/withRnForegroundService",
      "./plugins/withFixJcenter",
      "./plugins/withReactNativeFsFix",
      "./plugins/withNdkVersion",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
